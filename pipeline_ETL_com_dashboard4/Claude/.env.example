# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sales_etl_db
DB_USER=postgres
DB_PASSWORD=postgres

# API Configuration
API_BASE_URL=https://api.example.com
API_TIMEOUT=30

# File Paths
DATA_PATH=./data
REPORTS_PATH=./reports
LOGS_PATH=./logs

# Logging
LOG_LEVEL=INFO

# ETL Settings
BATCH_SIZE=1000
INCREMENTAL_PROCESSING=true

# Scheduler
SCHEDULE_INTERVAL=0 2 * * *  # 2 AM daily

# Dashboard
DASHBOARD_PORT=8501
DASHBOARD_HOST=0.0.0.0
