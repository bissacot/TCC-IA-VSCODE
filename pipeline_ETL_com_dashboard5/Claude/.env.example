# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sales_etl_db
DB_USER=etl_user
DB_PASSWORD=secure_password
DB_SCHEMA=public

# API Configuration
API_BASE_URL=https://api.example.com
API_TIMEOUT=30
API_RETRY_ATTEMPTS=3

# Data Source Paths
CSV_SALES_PATH=data/input/sales.csv
JSON_CUSTOMERS_PATH=data/input/customers.json
API_PRODUCTS_ENDPOINT=/api/v1/products

# Processing Configuration
BATCH_SIZE=1000
CHUNK_SIZE=10000
INCREMENTAL_MODE=true
LAST_RUN_TIMESTAMP_FILE=data/.last_run

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/etl.log

# Dashboard Configuration
DASHBOARD_PORT=8501
DASHBOARD_HOST=0.0.0.0

# Scheduling Configuration
AIRFLOW_HOME=/opt/airflow
SCHEDULER_ENABLED=false
ETL_SCHEDULE_INTERVAL=0 2 * * *  # Daily at 2 AM

# Report Configuration
REPORT_OUTPUT_DIR=data/output/reports
EXCEL_EXPORT_DIR=data/output/exports
PDF_REPORT_ENABLED=true

# Environment
ENVIRONMENT=development
DEBUG=false
