# Environment Variables Template

# Application Environment (development, production, testing)
ENVIRONMENT=development
DEBUG=False

# Logging Configuration
LOG_LEVEL=INFO

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=etl_user
DB_PASSWORD=etl_password
DB_NAME=sales_db

# API Configuration
PRODUCT_API_URL=https://jsonplaceholder.typicode.com/products
API_TIMEOUT=30
API_RETRIES=3

# ETL Configuration
BATCH_SIZE=1000
INCREMENTAL_LOAD=True
ALLOWED_DUPLICATES=0

# File Paths
CSV_SALES_FILE=sales_data.csv
JSON_CUSTOMERS_FILE=customers.json

# Dashboard Configuration
DASHBOARD_PORT=8501
DASHBOARD_MAX_UPLOAD_SIZE=200

# Report Generation
REPORTS_FORMAT=pdf,excel
PDF_ORIENTATION=portrait

# Scheduling
SCHEDULE_INTERVAL=0 2 * * *

# Performance and Caching
CACHE_ENABLED=True
CACHE_TTL_SECONDS=3600

# Data Quality Thresholds
MISSING_VALUE_THRESHOLD=0.1
DUPLICATE_THRESHOLD=0.05
